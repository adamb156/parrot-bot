# Discord
DISCORD_TOKEN=wstaw_token_bota
DISCORD_CLIENT_ID=wstaw_application_id

# Transcription provider: "openai" lub "groq"
TRANSCRIBE_PROVIDER=openai

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=whisper-1
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Groq (https://console.groq.com/keys) - opcjonalnie, darmowy tier
GROQ_API_KEY=
GROQ_MODEL=whisper-large-v3
GROQ_SUMMARY_MODEL=llama-3.3-70b-versatile
